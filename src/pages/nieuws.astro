---
import BaseLayout from "../layouts/BaseLayout.astro";
import { newsItems } from "../data/newsItems";

const featuredItem = newsItems[0];
const recentItems = newsItems.slice(1);
---

<BaseLayout title="Nieuws/updates | Confrérie des Fleurs">
  <section class="border-b border-stone-200 bg-[linear-gradient(90deg,#f8e7dc_0%,#f4e0d3_50%,#f8e7dc_100%)]">
    <div class="mx-auto w-full max-w-6xl px-4 py-3">
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-stone-800">
        <span class="font-semibold text-[#b45433]">Belangrijke data</span>
        <span><strong>17 mei</strong> Start bouwseizoen</span>
        <span><strong>7 juni</strong> Ontwerpkeuze definitief</span>
        <span><strong>4 sept</strong> Start bloemenweek</span>
        <span><strong>13 sept</strong> Bloemencorso Eelde</span>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 py-16">
    <p class="text-sm uppercase tracking-[0.2em] text-emerald-700">Confrérie des Fleurs</p>
    <h1 class="mt-3 text-4xl font-bold md:text-5xl">Nieuws/updates</h1>
    <p class="mt-4 max-w-3xl text-stone-600">
      Hier delen we het laatste nieuws uit de schuur, updates uit het bouwseizoen en belangrijke momenten richting het corso.
    </p>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <article class="rounded-2xl border border-stone-200 bg-[#f8f3ea] p-4">
        <p class="text-xs uppercase tracking-[0.16em] text-[#b45433]">Volgende mijlpaal</p>
        <p class="mt-2 text-2xl font-semibold">Corsoweek</p>
        <p class="mt-1 text-sm text-stone-600">Half september</p>
      </article>
      <article class="rounded-2xl border border-stone-200 bg-[#f8f3ea] p-4">
        <p class="text-xs uppercase tracking-[0.16em] text-[#b45433]">Processtappen</p>
        <p class="mt-2 text-2xl font-semibold">14 fases</p>
        <p class="mt-1 text-sm text-stone-600">Van ontwerp tot corso</p>
      </article>
      <article class="rounded-2xl border border-stone-200 bg-[#f8f3ea] p-4">
        <p class="text-xs uppercase tracking-[0.16em] text-[#b45433]">Laatste update</p>
        <p class="mt-2 text-2xl font-semibold">Vandaag</p>
        <p class="mt-1 text-sm text-stone-600">Nieuwe schuurbeelden</p>
      </article>
      <article class="rounded-2xl border border-stone-200 bg-[#f8f3ea] p-4">
        <p class="text-xs uppercase tracking-[0.16em] text-[#b45433]">Volg ons live</p>
        <p class="mt-2 text-2xl font-semibold">@corsowijk_cdf</p>
        <p class="mt-1 text-sm text-stone-600">Instagram updates</p>
      </article>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pb-10">
    <article class="rounded-2xl border border-stone-200 bg-[#f8f3ea] p-6">
      <h2 class="text-2xl font-semibold">Belangrijke data</h2>
      <p class="mt-3 text-stone-600">Een overzicht van de belangrijkste momenten in aanloop naar het corso.</p>
      <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
        <article class="rounded-xl border border-stone-200 bg-[#fffdf8] p-3">
          <p class="text-sm font-semibold text-[#b45433]">17 mei 2026</p>
          <p class="mt-1 text-sm text-stone-600">Start bouwseizoen en eerste gezamenlijke klusdag in de schuur.</p>
        </article>
        <article class="rounded-xl border border-stone-200 bg-[#fffdf8] p-3">
          <p class="text-sm font-semibold text-[#b45433]">7 juni 2026</p>
          <p class="mt-1 text-sm text-stone-600">Definitieve ontwerpkeuze en planning van alle bouwfases.</p>
        </article>
        <article class="rounded-xl border border-stone-200 bg-[#fffdf8] p-3">
          <p class="text-sm font-semibold text-[#b45433]">28 juni 2026</p>
          <p class="mt-1 text-sm text-stone-600">Constructiefase: skelet afronden en controle op techniek.</p>
        </article>
        <article class="rounded-xl border border-stone-200 bg-[#fffdf8] p-3">
          <p class="text-sm font-semibold text-[#b45433]">9 augustus 2026</p>
          <p class="mt-1 text-sm text-stone-600">Begin van decoratie en figuratie op de wagen.</p>
        </article>
        <article class="rounded-xl border border-stone-200 bg-[#fffdf8] p-3">
          <p class="text-sm font-semibold text-[#b45433]">4 september 2026</p>
          <p class="mt-1 text-sm text-stone-600">Bloemenweek: prikken, afwerken en laatste checks.</p>
        </article>
        <article class="rounded-xl border border-stone-200 bg-[#fffdf8] p-3">
          <p class="text-sm font-semibold text-[#b45433]">13 september 2026</p>
          <p class="mt-1 text-sm text-stone-600">Bloemencorso Eelde: op naar het parcours met de complete wagen.</p>
        </article>
      </div>
    </article>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pb-10">
    <article class="grid gap-6 rounded-3xl border border-stone-200 bg-[#f8f3ea] p-6 md:grid-cols-[1.1fr,1fr] md:p-8">
      <img src="https://picsum.photos/1000/650?random=700" alt="Bouwupdate uit de schuur" class="h-72 w-full rounded-2xl object-cover" />
      <div>
        <p class="text-xs uppercase tracking-[0.16em] text-[#b45433]">Uitgelichte update - {featuredItem.date}</p>
        <h2 class="mt-2 text-3xl font-semibold">{featuredItem.title}</h2>
        <p class="mt-3 text-stone-600">
          {featuredItem.excerpt}
        </p>
        <a href="https://www.instagram.com/corsowijk_cdf/" target="_blank" class="mt-5 inline-flex items-center gap-2 rounded-full bg-[#d36a42] px-4 py-2 text-sm font-medium text-white">
          Volg live op Instagram ↗
        </a>
      </div>
    </article>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pb-20">
    <h2 class="text-2xl font-semibold">Recente updates</h2>
    <div class="mt-5 grid gap-5 md:grid-cols-2">
      {
        recentItems.map((item) => (
          <article class="rounded-2xl border border-stone-200 bg-[#f8f3ea] p-5">
            <p class="text-xs uppercase tracking-[0.16em] text-[#b45433]">{item.label} - {item.date}</p>
            <h3 class="mt-2 text-xl font-semibold">{item.title}</h3>
            <p class="mt-2 text-sm text-stone-600">{item.excerpt}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
