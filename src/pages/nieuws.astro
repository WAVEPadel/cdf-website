---
import BaseLayout from "../layouts/BaseLayout.astro";
import { newsItems } from "../data/newsItems";

const featuredItem = newsItems[0];
const recentItems = newsItems.slice(1);
---

<BaseLayout title="Nieuws/updates | Confrérie des Fleurs">
  <section class="border-b border-stone-200 bg-[linear-gradient(90deg,#f8e7dc_0%,#f4e0d3_50%,#f8e7dc_100%)]">
    <div class="mx-auto w-full max-w-6xl px-4 py-3">
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-stone-800">
        <span class="font-semibold text-[#b45433]">Belangrijke data</span>
        <span><strong>11 april</strong> Start bouw tent</span>
        <span><strong>9 mei</strong> Open inloopavond</span>
        <span><strong>6 juni</strong> Feestavond</span>
        <span><strong>22 augustus</strong> BBQ</span>
        <span><strong>5 &amp; 6 september</strong> Bloemencorso</span>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 py-16">
    <p class="cdf-eyebrow">Confrérie des Fleurs</p>
    <h1 class="mt-3 text-3xl font-bold md:text-4xl">Nieuws/updates</h1>
    <p class="mt-4 max-w-3xl text-stone-600">
      Hier delen we het laatste nieuws uit de schuur, updates uit het bouwseizoen en belangrijke momenten richting het corso.
    </p>

  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pb-10">
    <article class="cdf-surface-card rounded-2xl p-6">
      <h2 class="text-2xl font-semibold">Belangrijke data</h2>
      <p class="mt-3 text-stone-600">Een overzicht van de belangrijkste momenten in aanloop naar het corso.</p>
      <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
        <article class="cdf-surface-card rounded-xl p-3">
          <p class="text-sm font-semibold text-[#b45433]">11 april 2026</p>
          <p class="mt-1 text-sm text-stone-600">Start bouw tent en eerste opbouwdag op locatie.</p>
        </article>
        <article class="cdf-surface-card rounded-xl p-3">
          <p class="text-sm font-semibold text-[#b45433]">9 mei 2026</p>
          <p class="mt-1 text-sm text-stone-600">Open inloopavond voor iedereen die wil meekijken of meehelpen.</p>
        </article>
        <article class="cdf-surface-card rounded-xl p-3">
          <p class="text-sm font-semibold text-[#b45433]">6 juni 2026</p>
          <p class="mt-1 text-sm text-stone-600">Feestavond met de ploeg en supporters van Confrérie des Fleurs.</p>
        </article>
        <article class="cdf-surface-card rounded-xl p-3">
          <p class="text-sm font-semibold text-[#b45433]">22 augustus 2026</p>
          <p class="mt-1 text-sm text-stone-600">Gezamenlijke BBQ als opwarmer richting de corsoweek.</p>
        </article>
        <article class="cdf-surface-card rounded-xl p-3">
          <p class="text-sm font-semibold text-[#b45433]">5 &amp; 6 september 2026</p>
          <p class="mt-1 text-sm text-stone-600">Bloemencorso: twee dagen vol sfeer, figuratie en wagens op topniveau.</p>
        </article>
      </div>
    </article>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pb-10">
    <article class="cdf-surface-card grid gap-6 rounded-3xl p-6 md:grid-cols-[1.1fr,1fr] md:p-8">
      <img src="/nieuws-ontwerp-2026.png" alt="Maquette van het ontwerp voor 2026" class="h-64 w-full rounded-2xl object-cover object-center sm:h-72 md:h-full md:min-h-[320px]" />
      <div>
        <p class="text-xs uppercase tracking-[0.16em] text-[#b45433]">Uitgelichte update - {featuredItem.date}</p>
        <h2 class="mt-2 text-2xl font-semibold">{featuredItem.title}</h2>
        <p class="mt-3 text-stone-600">
          {featuredItem.excerpt}
        </p>
        <a href="https://www.instagram.com/corsowijk_cdf/" target="_blank" class="mt-5 inline-flex items-center gap-2 rounded-full bg-[#d36a42] px-4 py-2 text-sm font-medium text-white">
          Volg live op Instagram ↗
        </a>
      </div>
    </article>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pb-20">
    <h2 class="text-2xl font-semibold">Recente updates</h2>
    <div class="mt-5 grid gap-5 md:grid-cols-2">
      {
        recentItems.map((item) => (
          <article class="cdf-surface-card rounded-2xl p-5">
            <p class="text-xs uppercase tracking-[0.16em] text-[#b45433]">{item.label} - {item.date}</p>
            <h3 class="mt-2 text-xl font-semibold">{item.title}</h3>
            <p class="mt-2 text-sm text-stone-600">{item.excerpt}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
