---
import BaseLayout from "../layouts/BaseLayout.astro";

const wagens = [
  { jaar: "2025", naam: "Oase", beschrijving: "Een verfrissende oase in de woestijn, tot leven gebracht met duizenden bloemen.", prijs: "6e", image: "/archief-oase.png" },
  { jaar: "2024", naam: "Bromtollen", beschrijving: "Een kleurrijke ode aan het klassieke kinderspeelgoed, tot leven gebracht met duizenden bloemen.", prijs: "10e", image: "/archief-bromtollen.png" },
  { jaar: "2023", naam: "Expeditie Lapland", beschrijving: "Een magische reis naar het hoge noorden, compleet met noorderlicht en rendieren.", prijs: "9e", image: "/archief-expeditie-lapland.png" },
  { jaar: "2019", naam: "Achter de Schermen", beschrijving: "Een kijkje achter de coulissen van de filmwereld.", prijs: "1B", image: "/archief-achter-de-schermen.png" },
  { jaar: "2018", naam: "Mardi Gras", beschrijving: "De uitbundige sfeer van New Orleans gevangen in bloemen.", prijs: "1D", image: "/archief-mardi-gras.png" },
  { jaar: "2017", naam: "Perzië", beschrijving: "Oosterse pracht en praal uit het oude Perzische rijk.", prijs: "1C", image: "/archief-perzie.png" },
  { jaar: "2016", naam: "Het Draaiorgel", beschrijving: "Een meesterwerk dat geschiedenis schreef. Het draaiorgel kwam tot leven met ongekende precisie en vakmanschap.", prijs: "Eerste- en Ereprijs | Ontwerpersprijs | Arrangeursprijs | Figuratieprijs | Publieksprijs", image: "/archief-draaiorgel.png" },
  { jaar: "2015", naam: "Jaarringen", beschrijving: "De groei van de natuur vertaald in een indrukwekkende bloemencreatie.", prijs: "1B | Ontwerpersprijs", image: "/archief-jaarringen.png" },
  { jaar: "2012", naam: "De Trip", beschrijving: "Een psychedelische reis door tijd en ruimte, bekroond met de hoogste eer.", prijs: "Eerste- en Ereprijs | Figuratieprijs", image: "/archief-de-trip.png" },
  { jaar: "1997", naam: "Flintstones", beschrijving: "De prehistorische familie uit Bedrock kwam tot leven. De laatste wagen van de eerste periode, afgesloten met het grootste feest.", prijs: "", image: "/archief-flintstones.png" },
];
---

<BaseLayout title="Door de jaren heen | Confrérie des Fleurs">
  <section class="mx-auto w-full max-w-6xl px-4 py-16">
    <p class="cdf-eyebrow">Confrérie des Fleurs</p>
    <h1 class="mt-3 text-3xl font-bold md:text-4xl">Door de jaren heen</h1>
    <p class="mt-4 max-w-3xl text-stone-600">Een overzicht van alle wagens van Confrérie des Fleurs door de jaren heen.</p>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pb-20">
    <p class="cdf-eyebrow">Archief</p>
    <h2 class="mt-3 text-2xl font-semibold">Alle wagens</h2>
    <p class="mt-3 text-stone-600">{wagens.length} wagens in het archief</p>
    <div class="mt-8 grid gap-4">
      {
        wagens.map((wagen) => (
          <article class="grid gap-4 cdf-surface-card rounded-xl p-4 md:grid-cols-[minmax(300px,360px)_1fr]">
            <img
              src={wagen.image}
              alt={`Wagen ${wagen.naam}`}
              class="h-[220px] w-full rounded-xl object-cover md:h-[250px]"
            />
            <div>
              <p class="text-sm text-emerald-700">{wagen.jaar}</p>
              <h3 class="mt-1 text-xl font-semibold">{wagen.naam}</h3>
              <p class="mt-2 text-stone-600">{wagen.beschrijving}</p>
              {
                wagen.prijs && (
                  <div class="mt-3 flex flex-wrap items-center gap-2">
                    <span aria-hidden="true" class="text-base">🏆</span>
                    {wagen.prijs.split("|").map((prijs) => (
                      <span class="rounded-full border border-[#ead7af] bg-[#efdeb8] px-3 py-1 text-sm font-medium text-stone-800">
                        {prijs.trim()}
                      </span>
                    ))}
                  </div>
                )
              }
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
