---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;

const navItems = [
  { href: "/", label: "Home" },
  {
    label: "Historie & Archief",
    children: [
      { href: "/historie", label: "Historie CDF" },
      { href: "/door-de-jaren-heen", label: "Door de jaren heen" },
    ],
  },
  { href: "/nieuws", label: "Nieuws/updates" },
  { href: "/contact", label: "Contact" },
];

const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png?v=20260408b" />
    <link rel="shortcut icon" type="image/png" href="/favicon.png?v=20260408b" />
    <link rel="apple-touch-icon" href="/favicon.png?v=20260408b" />
    <title>{title}</title>
  </head>
  <body class="bg-[#f5efe2] text-stone-900">
    <header class="sticky top-0 z-50 border-b border-stone-200 bg-white/95 backdrop-blur">
      <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-4">
        <a href="/" class="inline-flex items-center gap-2 text-lg font-semibold tracking-wide text-stone-900">
          <span class="text-xs text-[#c95c36]">❀</span>
          <span>Confrérie des Fleurs</span>
        </a>
        <nav class="hidden items-center gap-2 text-sm md:flex">
          {
            navItems.map((item) =>
              item.children ? (
                <div class="group relative" data-dropdown>
                  <button
                    type="button"
                    data-dropdown-toggle
                    aria-expanded="false"
                    class:list={[
                      "inline-flex items-center gap-1 rounded-full px-3 py-1.5 transition hover:text-stone-900",
                      (pathname === "/historie" || pathname === "/door-de-jaren-heen")
                        ? "bg-[#d36a42] text-white"
                        : "text-stone-700",
                    ]}
                  >
                    {item.label}
                    <span aria-hidden="true">▾</span>
                  </button>
                  <div
                    data-dropdown-menu
                    class="invisible absolute left-0 top-full z-40 mt-2 min-w-52 rounded-xl border border-stone-200 bg-white p-2 opacity-0 shadow-sm transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
                  >
                    {item.children.map((child) => (
                      <a
                        href={child.href}
                        class:list={[
                          "block rounded-lg px-3 py-2 text-sm transition hover:bg-stone-100",
                          pathname === child.href ? "bg-stone-100 text-stone-900" : "text-stone-700",
                        ]}
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              ) : (
                <a
                  href={item.href}
                  class:list={[
                    "rounded-full px-3 py-1.5 transition hover:text-stone-900",
                    pathname === item.href ? "bg-[#d36a42] text-white" : "text-stone-700",
                  ]}
                >
                  {item.label}
                </a>
              ),
            )
          }
          <a href="https://www.instagram.com/corsowijk_cdf/" target="_blank" class="rounded-full px-3 py-1.5 text-stone-700 transition hover:text-stone-900">
            Instagram ↗
          </a>
          <a
            href="/frikandellenlijst"
            class="inline-flex items-center transition hover:scale-105"
            title="Open frikandellenlijst"
            aria-label="Open frikandellenlijst"
          >
            <img
              src="/frikandel-knop.png"
              alt="Frikandel knop"
              class="h-10 w-20 object-contain"
            />
          </a>
        </nav>
        <button
          id="menu-toggle"
          type="button"
          class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-stone-300 text-stone-700 md:hidden"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Open menu"
        >
          ☰
        </button>
      </div>
      <div id="mobile-menu" class="hidden border-t border-stone-200 bg-white px-4 py-3 md:hidden">
        <nav class="flex flex-col gap-3 text-sm">
          {
            navItems.map((item) =>
              item.children ? (
                <div class="rounded-md border border-stone-200 bg-stone-50 p-2">
                  <p class="px-2 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-stone-500">{item.label}</p>
                  <div class="mt-1 flex flex-col">
                    {item.children.map((child) => (
                      <a
                        href={child.href}
                        class:list={[
                          "rounded-md px-3 py-2 transition hover:bg-emerald-50 hover:text-emerald-700",
                          pathname === child.href && "bg-emerald-50 text-emerald-700",
                        ]}
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              ) : (
                <a
                  href={item.href}
                  class:list={[
                    "rounded-md px-3 py-2 transition hover:bg-emerald-50 hover:text-emerald-700",
                    pathname === item.href && "bg-emerald-50 text-emerald-700",
                  ]}
                >
                  {item.label}
                </a>
              ),
            )
          }
          <a href="https://www.instagram.com/corsowijk_cdf/" target="_blank" class="rounded-md px-3 py-2 text-stone-700 transition hover:bg-emerald-50 hover:text-emerald-700">
            Instagram ↗
          </a>
          <a href="/frikandellenlijst" class="rounded-md px-3 py-2 text-stone-700 transition hover:bg-emerald-50 hover:text-emerald-700">
            Frikandellenlijst
          </a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="mt-14 border-t border-[#e3c6b8] bg-[linear-gradient(180deg,#f3dfd4_0%,#efd9cc_35%,#e8d1c1_100%)]">
      <div class="mx-auto w-full max-w-6xl px-4 py-8">
        <div class="grid gap-8 md:grid-cols-[1.35fr_0.9fr_1fr] md:gap-10">
          <div>
            <p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-[#a55033]">
              <span>❀</span>
              <span>Confrérie des Fleurs</span>
            </p>
            <h3 class="mt-3 text-3xl font-semibold text-stone-900">Corsowijk Eelde</h3>
            <p class="mt-3 max-w-md text-stone-700">
              Vriendschap, creativiteit en corsokoorts in Eelde. Al sinds 1973 bouwen wij met passie aan onze corsowagen.
            </p>
            <p class="mt-3 text-sm text-stone-600">Siegerslag 2, Eelde (voorbeeld, controleren)</p>
            <p class="mt-4 text-lg italic text-[#7a4b35]">Ook dat is Confrérie!</p>
          </div>

          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-stone-700">Navigatie</p>
            <nav class="mt-4 flex flex-col gap-2 text-sm text-stone-700">
              <a href="/" class="transition hover:text-[#b45433]">Home</a>
              <a href="/historie" class="transition hover:text-[#b45433]">Historie CDF</a>
              <a href="/door-de-jaren-heen" class="transition hover:text-[#b45433]">Door de jaren heen</a>
              <a href="/nieuws" class="transition hover:text-[#b45433]">Nieuws/updates</a>
              <a href="/contact" class="transition hover:text-[#b45433]">Contact</a>
              <a href="https://www.instagram.com/corsowijk_cdf/" target="_blank" class="transition hover:text-[#b45433]">
                Instagram ↗
              </a>
            </nav>
          </div>

          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-stone-700">Sponsor worden</p>
            <p class="mt-4 text-sm text-stone-700">
              Sponsors zijn altijd welkom bij Confrérie des Fleurs. Neem gerust contact met ons op.
            </p>
            <a
              href="/contact"
              class="mt-4 inline-flex items-center gap-2 rounded-full border border-[#d1a692] bg-white/70 px-4 py-2 text-sm font-medium text-[#8a442a] transition hover:bg-white"
            >
              Meer informatie <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <div class="mt-6 border-t border-[#d9b9a8] pt-4 text-xs text-stone-600 md:flex md:items-center md:justify-between">
          <p>Confrérie des Fleurs, Eelde</p>
          <p>Ook dat is Confrérie!</p>
        </div>
      </div>
    </footer>
    <script>
      const menu = document.getElementById("mobile-menu");
      const toggle = document.getElementById("menu-toggle");
      const dropdowns = Array.from(document.querySelectorAll("[data-dropdown]"));

      toggle?.addEventListener("click", () => {
        const isHidden = menu?.classList.contains("hidden");
        menu?.classList.toggle("hidden");
        toggle.setAttribute("aria-expanded", isHidden ? "true" : "false");
      });

      dropdowns.forEach((dropdown) => {
        const btn = dropdown.querySelector("[data-dropdown-toggle]");
        const panel = dropdown.querySelector("[data-dropdown-menu]");

        if (!btn || !panel) return;

        const closePanel = () => {
          panel.classList.add("invisible", "opacity-0");
          btn.setAttribute("aria-expanded", "false");
        };

        const openPanel = () => {
          panel.classList.remove("invisible", "opacity-0");
          btn.setAttribute("aria-expanded", "true");
        };

        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const isClosed = panel.classList.contains("invisible");

          dropdowns.forEach((other) => {
            if (other !== dropdown) {
              const otherBtn = other.querySelector("[data-dropdown-toggle]");
              const otherPanel = other.querySelector("[data-dropdown-menu]");
              otherPanel?.classList.add("invisible", "opacity-0");
              otherBtn?.setAttribute("aria-expanded", "false");
            }
          });

          if (isClosed) openPanel();
          else closePanel();
        });

        document.addEventListener("click", (e) => {
          if (!dropdown.contains(e.target)) closePanel();
        });

        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") closePanel();
        });
      });
    </script>
  </body>
</html>
